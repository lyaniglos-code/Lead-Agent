# ---------------------------------------------------------------------------
# Environment variable TEMPLATE for the Lead Follow-Up Agent.
#
# HOW THIS WORKS:
#   - This file (.env.local.example) is committed to git. It contains NO real
#     secrets — only the NAMES of the variables the app needs. It acts as a
#     checklist so anyone cloning the repo knows what to configure.
#   - You create a real, UNCOMMITTED file called `.env.local` (ignored by git)
#     and paste your actual keys there.
#
# Copy this file:   cp .env.local.example .env.local
# Then fill in the real values in .env.local.
#
# NEXT.JS RULE: variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Everything WITHOUT that prefix stays server-only and is never shipped to the
# client. Secret keys must NEVER use the NEXT_PUBLIC_ prefix.
# ---------------------------------------------------------------------------

# --- Supabase (database) -------------------------------------------------
# Added in Milestone 4.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key with elevated privileges — used by our API routes to write
# leads. Must stay secret; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (lead analysis + email generation) ---------------------------
# Added in Milestone 5.
OPENAI_API_KEY=

# --- Resend (transactional email) ----------------------------------------
# Added in Milestone 6.
RESEND_API_KEY=
# The verified "from" address your follow-up emails are sent from.
RESEND_FROM_EMAIL=

# --- Twilio (SMS reminders — added later) --------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
